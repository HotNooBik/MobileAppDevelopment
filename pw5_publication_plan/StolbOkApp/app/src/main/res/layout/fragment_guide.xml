<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Mini logo -->
    <ImageView
        android:id="@+id/logo"
        android:layout_width="wrap_content"
        android:layout_height="60dp"
        android:layout_marginTop="52dp"
        android:layout_marginBottom="16dp"
        android:layout_gravity="center_horizontal"
        android:src="@drawable/img_header_mini_logo"
        android:contentDescription="@string/guide_logo_desc" />

    <!-- Tab row -->
    <LinearLayout
        android:id="@+id/tabRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tabClothing"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/tab_clothing"
            android:textSize="16sp"
            android:gravity="center"
            android:paddingTop="8dp"
            android:paddingBottom="8dp" />

        <TextView
            android:id="@+id/tabSafety"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/tab_safety"
            android:textSize="16sp"
            android:gravity="center"
            android:paddingTop="8dp"
            android:paddingBottom="8dp" />

        <TextView
            android:id="@+id/tabSeasons"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/tab_seasons"
            android:textSize="16sp"
            android:gravity="center"
            android:paddingTop="8dp"
            android:paddingBottom="8dp" />

    </LinearLayout>

    <!-- Divider under tabs -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/stroke_dark" />

    <!-- Tab indicator line -->
    <View
        android:id="@+id/tabIndicator"
        android:layout_width="0dp"
        android:layout_height="3dp"
        android:background="@color/brand_primary" />

    <!-- Content area: FrameLayout with 3 tab contents -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Clothing tab -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/contentClothing"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="16dp">

                <include
                    android:id="@+id/clothingCard1"
                    layout="@layout/item_guide_card" />

                <include layout="@layout/item_guide_card_placeholder" />
                <include layout="@layout/item_guide_card_placeholder" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- Safety tab -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/contentSafety"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="16dp">

                <include
                    android:id="@+id/safetyCard1"
                    layout="@layout/item_guide_card" />

                <include layout="@layout/item_guide_card_placeholder" />
                <include layout="@layout/item_guide_card_placeholder" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- Seasons tab -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/contentSeasons"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="16dp">

                <include
                    android:id="@+id/seasonsCard1"
                    layout="@layout/item_guide_card" />

                <include layout="@layout/item_guide_card_placeholder" />
                <include layout="@layout/item_guide_card_placeholder" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </FrameLayout>

</LinearLayout>
