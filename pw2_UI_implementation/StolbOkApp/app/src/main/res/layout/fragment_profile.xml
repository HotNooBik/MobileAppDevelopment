<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="80dp">

            <!-- Mini logo -->
            <ImageView
                android:id="@+id/logo"
                android:layout_width="wrap_content"
                android:layout_height="60dp"
                android:layout_marginTop="52dp"
                android:src="@drawable/img_header_mini_logo"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Exit btn -->
            <ImageButton
                android:id="@+id/exitBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="60dp"
                android:layout_marginEnd="14dp"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_exit"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Profile img -->
            <ImageView
                android:id="@+id/imageView2"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_marginTop="140dp"
                android:src="@drawable/img_profile_avatar"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Profile info -->
            <TextView
                android:id="@+id/tvProfileSince"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Хожу на Столбы с 2025"
                android:textStyle="bold"
                android:textSize="24sp"
                android:textColor="@color/text_primary"
                app:layout_constraintEnd_toEndOf="@+id/imageView2"
                app:layout_constraintHorizontal_bias="0.504"
                app:layout_constraintStart_toStartOf="@+id/imageView2"
                app:layout_constraintTop_toBottomOf="@+id/imageView2" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/profileInfoContainer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:layout_marginHorizontal="16dp"
                app:layout_constraintTop_toBottomOf="@+id/tvProfileSince"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- Days in Info Tile -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/daysInInfoTile"
                    android:layout_width="0dp"
                    android:layout_height="68dp"
                    android:background="@drawable/bg_profile_tile"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <ImageView
                        android:id="@+id/ivDaysIcon"
                        android:layout_width="35dp"
                        android:layout_height="35dp"
                        android:layout_marginStart="16dp"
                        android:src="@drawable/ic_calendar_profile"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <TextView
                        android:id="@+id/tvDaysLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Дней на Столбах"
                        android:textColor="@color/text_secondary"
                        android:textSize="22sp"
                        app:layout_constraintStart_toEndOf="@+id/ivDaysIcon"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@+id/daysDivider" />

                    <View
                        android:id="@+id/daysDivider"
                        android:layout_width="1dp"
                        android:layout_height="50dp"
                        android:layout_marginEnd="16dp"
                        android:background="@color/stroke_dark"
                        app:layout_constraintEnd_toStartOf="@+id/tvDaysValue"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <TextView
                        android:id="@+id/tvDaysValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="24dp"
                        android:text="1"
                        android:textColor="@color/text_primary"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Visited peaks count Info Tile -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/visitedPeaksInfoTile"
                    android:layout_width="0dp"
                    android:layout_height="68dp"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_profile_tile"
                    app:layout_constraintTop_toBottomOf="@+id/daysInInfoTile"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <ImageView
                        android:id="@+id/ivPeaksIcon"
                        android:layout_width="35dp"
                        android:layout_height="35dp"
                        android:layout_marginStart="16dp"
                        android:src="@drawable/ic_mountains_profile"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <TextView
                        android:id="@+id/tvPeaksLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Посещенные скалы"
                        android:textColor="@color/text_secondary"
                        android:textSize="22sp"
                        app:layout_constraintStart_toEndOf="@+id/ivPeaksIcon"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@+id/peaksDivider" />

                    <View
                        android:id="@+id/peaksDivider"
                        android:layout_width="1dp"
                        android:layout_height="50dp"
                        android:layout_marginEnd="16dp"
                        android:background="@color/stroke_dark"
                        app:layout_constraintEnd_toStartOf="@+id/tvPeaksValue"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <TextView
                        android:id="@+id/tvPeaksValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="24dp"
                        android:text="4/23"
                        android:textColor="@color/text_primary"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Tabs -->
            <LinearLayout
                android:id="@+id/tabsContainer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@+id/profileInfoContainer"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:id="@+id/tabHistory"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="История"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/brand_primary"
                        android:paddingVertical="14dp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:background="@color/brand_primary"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/tabPlans"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Запланировано"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#80242C26"
                        android:paddingVertical="14dp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:background="@android:color/transparent"/>
                </LinearLayout>

            </LinearLayout>

            <View
                android:id="@+id/tabsDivider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/stroke_dark"
                app:layout_constraintTop_toBottomOf="@+id/tabsContainer"/>

            <!-- History Content -->
            <LinearLayout
                android:id="@+id/historyContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="16dp"
                android:clipToPadding="false"
                android:visibility="visible"
                app:layout_constraintTop_toBottomOf="@+id/tabsDivider">

                <!-- History Item -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/historyItem"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_profile_tile"
                    android:padding="0dp"
                    android:layout_marginBottom="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <TextView
                        android:id="@+id/tvHistoryDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Сб, 4 Апреля, 2025"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        android:layout_marginStart="16dp"/>

                    <androidx.cardview.widget.CardView
                        android:layout_width="92dp"
                        android:layout_height="57dp"
                        android:layout_margin="12dp"
                        app:cardCornerRadius="10dp"
                        app:cardElevation="0dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/img_history_1"
                            android:scaleType="centerCrop"
                            android:contentDescription="@null" />
                    </androidx.cardview.widget.CardView>

                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- History item unloaded 1 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:background="@drawable/bg_profile_tile"
                    android:backgroundTint="#D9D9D9"
                    android:layout_marginBottom="12dp"/>

                <!-- History item unloaded 2 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:background="@drawable/bg_profile_tile"
                    android:backgroundTint="#D9D9D9"
                    android:layout_marginBottom="12dp"/>

            </LinearLayout>

            <!-- Plans Content -->
            <LinearLayout
                android:id="@+id/plansContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="16dp"
                android:clipToPadding="false"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@+id/tabsDivider">

                <!-- Plans Item -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/plansItem"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_profile_tile"
                    android:padding="0dp"
                    android:layout_marginBottom="19dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <View
                        android:id="@+id/view"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_day_awesome"
                        android:layout_marginStart="11dp"
                        android:layout_marginVertical="11dp"
                        app:layout_constraintBottom_toBottomOf="@+id/tvPlansDate"
                        app:layout_constraintEnd_toStartOf="@+id/tvPlansDate"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="@+id/tvPlansDate" />

                    <TextView
                        android:id="@+id/tvPlansDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Сб, 16 Мая, 2026"
                        android:textColor="@color/text_secondary"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toEndOf="@id/view"
                        app:layout_constraintTop_toTopOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Plan item unloaded 1 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:background="@drawable/bg_profile_tile"
                    android:backgroundTint="#D9D9D9"
                    android:layout_marginBottom="19dp"/>

                <!-- Plan item unloaded 2 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:background="@drawable/bg_profile_tile"
                    android:backgroundTint="#D9D9D9"
                    android:layout_marginBottom="19dp"/>

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/addHistoryBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="20dp"
        android:src="@drawable/ic_add_plus"
        android:contentDescription="Add"
        app:backgroundTint="@color/brand_primary"
        app:tint="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
