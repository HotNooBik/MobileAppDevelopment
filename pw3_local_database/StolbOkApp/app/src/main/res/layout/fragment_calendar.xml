<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Mini logo -->
            <ImageView
                android:id="@+id/logo"
                android:layout_width="wrap_content"
                android:layout_height="60dp"
                android:layout_marginTop="52dp"
                android:src="@drawable/img_header_mini_logo"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <View
                android:id="@+id/view2"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="18dp"
                android:background="@color/stroke_dark"
                app:layout_constraintTop_toBottomOf="@id/logo" />

            <!-- Main label -->
            <TextView
                android:id="@+id/textView2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="13dp"
                android:text="Календарь Столбов"
                android:textColor="@color/text_primary"
                android:textSize="32sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/view2" />

            <!-- Today label -->
            <TextView
                android:id="@+id/textView3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Сегодня:"
                android:textColor="@color/text_primary"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginTop="9dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/textView2" />

            <View
                android:layout_width="wrap_content"
                android:layout_height="1dp"
                android:background="@color/stroke_dark"
                android:layout_marginEnd="10dp"
                app:layout_constraintBottom_toBottomOf="@+id/textView3"
                app:layout_constraintEnd_toStartOf="@+id/textView3"
                app:layout_constraintTop_toTopOf="@+id/textView3" />

            <View
                android:layout_width="wrap_content"
                android:layout_height="1dp"
                android:background="@color/stroke_dark"
                android:layout_marginStart="10dp"
                app:layout_constraintBottom_toBottomOf="@+id/textView3"
                app:layout_constraintStart_toEndOf="@+id/textView3"
                app:layout_constraintTop_toTopOf="@+id/textView3" />

            <!-- Current day information -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/constraintLayout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/textView3">

                <LinearLayout
                    android:id="@+id/ll1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    app:layout_constraintEnd_toStartOf="@id/ll2">

                    <!-- Current month -->
                    <TextView
                        android:id="@+id/tvCurrentMonth"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="2dp"
                        android:text="Май"
                        android:textColor="@color/black"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <!-- Current day number -->
                    <TextView
                        android:id="@+id/tvCurrentDayNumber"
                        android:layout_width="108dp"
                        android:layout_height="108dp"
                        android:background="@drawable/bg_day_not_good_big"
                        android:gravity="center"
                        android:text="1"
                        android:textAlignment="center"
                        android:textColor="@color/black"
                        android:textSize="57sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ll2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="15dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    app:layout_constraintBottom_toBottomOf="@id/ll1"
                    app:layout_constraintStart_toEndOf="@id/ll1"
                    app:layout_constraintTop_toTopOf="@id/ll1">

                    <!-- Current day status -->
                    <TextView
                        android:id="@+id/tvCurrentDayStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"
                        android:text="Плохой день"
                        android:textColor="@color/text_primary"
                        android:textSize="32dp"
                        android:textStyle="bold" />

                    <View
                        android:id="@+id/view2"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="3dp"
                        android:layout_marginBottom="14dp"
                        android:background="@color/stroke_dark" />

                    <!-- Current weather -->
                    <TextView
                        android:id="@+id/tvCurrentWeather"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:drawableEnd="@drawable/ic_weather_weak_rain"
                        android:drawablePadding="10dp"
                        android:text="Слабый дождь"
                        android:textColor="#CF242C26"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <View
                android:id="@+id/dividerAfterToday"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/stroke_dark"
                android:layout_marginTop="25dp"
                app:layout_constraintTop_toBottomOf="@+id/constraintLayout"/>

            <!-- Month chips scroll -->
            <HorizontalScrollView
                android:id="@+id/monthChipsScroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:scrollbars="none"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:clipToPadding="false"
                app:layout_constraintTop_toBottomOf="@+id/dividerAfterToday"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:id="@+id/monthChipsContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/chipJan"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Янв"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_chip_unselected"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:id="@+id/chipFeb"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Фев"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_chip_unselected"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:id="@+id/chipMar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Мар"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_chip_unselected"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:id="@+id/chipApr"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Апр"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_chip_unselected"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:id="@+id/chipMay"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Май"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_chip_selected"
                        android:textColor="@color/white" />

                    <TextView
                        android:id="@+id/chipJun"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Июн"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_chip_unselected"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:id="@+id/chipJul"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Июл"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_chip_unselected"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:id="@+id/chipAug"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Авг"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_chip_unselected"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:id="@+id/chipSep"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Сен"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_chip_unselected"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:id="@+id/chipOct"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Окт"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_chip_unselected"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:id="@+id/chipNov"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ноя"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_chip_unselected"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:id="@+id/chipDec"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Дек"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:background="@drawable/bg_chip_unselected"
                        android:textColor="@color/text_primary" />

                </LinearLayout>

            </HorizontalScrollView>

            <!-- Day-of-week header row -->
            <LinearLayout
                android:id="@+id/weekHeaderRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="14dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                app:layout_constraintTop_toBottomOf="@+id/monthChipsScroll"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Пн"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Вт"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Ср"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Чт"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Пт"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Сб"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Вс"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary" />

            </LinearLayout>

            <!-- Calendar grid container (rows will be added programmatically) -->
            <LinearLayout
                android:id="@+id/calendarGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="6dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingBottom="100dp"
                app:layout_constraintTop_toBottomOf="@+id/weekHeaderRow"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>


</androidx.constraintlayout.widget.ConstraintLayout>

